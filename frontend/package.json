{
  "name": "q2sc-electron-client",
  "version": "0.1.0-alpha",
  "description": "Q2SC — Quantum & QSAR Spectral Chemistry Platform desktop client",
  "author": {
    "name": "Vlad Myahlov",
    "email": "myahlov@gmail.com"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --dir",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:build:mac": "npm run build && electron-builder --mac --x64",
    "electron:build:all": "npm run build && electron-builder --win --mac --x64",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "3dmol": "^2.5.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "10.0.3",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "vite": "8.0.16",
    "wait-on": "9.0.10"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3"
  },
  "build": {
    "appId": "com.q2sc.desktop",
    "productName": "Q2SC Platform",
    "copyright": "Copyright © 2024 Vlad Myahlov",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icons/icon.ico",
      "artifactName": "Q2SC-Platform-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Q2SC Platform"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Q2SC-Platform-${version}-${arch}.${ext}",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "Q2SC Platform ${version}",
      "background": null,
      "window": { "width": 540, "height": 380 }
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icons",
      "category": "Science",
      "artifactName": "Q2SC-Platform-${version}.${ext}"
    }
  }
}
