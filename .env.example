Q2SC_ENV=development
Q2SC_API_HOST=0.0.0.0
Q2SC_API_PORT=8000
Q2SC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+asyncpg://q2sc:q2sc_password@postgres:5432/q2sc
SYNC_DATABASE_URL=postgresql://q2sc:q2sc_password@postgres:5432/q2sc
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=q2sc_storage
S3_SECRET_KEY=q2sc_storage_password
S3_BUCKET=q2sc-spectral-vault
MINIO_ROOT_USER=q2sc_storage
MINIO_ROOT_PASSWORD=q2sc_storage_password
POSTGRES_USER=q2sc
POSTGRES_PASSWORD=q2sc_password
POSTGRES_DB=q2sc
